{
  "name": "entropy-edge",
  "private": true,
  "version": "0.1.0",
  "description": "Structural duel roguelite — a Scrabble-like race to satisfy tier-connectivity objectives while stability physics judge every placement. Built on @jolly-pixel/voxel.renderer.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "compile-content": "node scripts/compile-content.mjs",
    "generate-tileset": "node scripts/generate-tileset.mjs",
    "predev": "pnpm run compile-content && pnpm run generate-tileset",
    "prebuild": "pnpm run compile-content && pnpm run generate-tileset",
    "pretypecheck": "pnpm run compile-content",
    "pretest": "pnpm run compile-content",
    "pretest:node": "pnpm run compile-content",
    "pretest:dom": "pnpm run compile-content",
    "pretest:browser": "pnpm run compile-content && pnpm run generate-tileset",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome lint .",
    "check:format": "biome format .",
    "test": "pnpm run test:node && pnpm run test:dom",
    "test:node": "vitest run --config vitest.config.ts",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:browser": "vitest --config vitest.browser.config.ts --browser --run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "@jolly-pixel/engine": "^2.5.0",
    "@jolly-pixel/runtime": "^3.3.0",
    "@jolly-pixel/voxel.renderer": "^1.4.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "seedrandom": "^3.0.5",
    "three": "^0.184.0",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.184.0",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "jsdom": "^27.0.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "three": "^0.184.0",
      "@types/three": "^0.184.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "three": "^0.184.0"
      }
    }
  }
}
